{
   "id": "intersight_config_orgs_unified_edge_profiles#",
   "$schema": "http://json-schema.org/draft-07/schema#",
   "title": "EasyUCS intersight config orgs unified_edge_profiles section",
   "description": "EasyUCS intersight config orgs unified_edge_profiles section JSON schema",
   "type": "object",
   "properties": {
      "comment": {
         "description": "Unified Edge Profile Comments",
         "type": "string",
         "default": ""
      },
      "descr": {
         "description": "Unified Edge Profile Description",
         "type": "string",
         "default": "",
         "pattern": "^$|^[a-zA-Z0-9]+[\\x00-\\xFF]*$",
         "maxLength": 1024
      },
      "name": {
         "description": "Unified Edge Profile Name",
         "type": "string",
         "default": "",
         "pattern": "^[a-zA-Z0-9_.-]{1,64}$"
      },
      "user_label": {
         "description": "Unified Edge Profile User Label",
         "type": "string",
         "default": "",
         "pattern": "^[a-zA-Z0-9 !#$%&*+,()\\[\\]{}|/.?@_:;~-]{1,64}$"
      },
      "tags": {
         "description": "Unified Edge Profile Tags",
         "type": "array",
         "items": {
            "description": "Unified Edge Profile Tag",
            "type": "object",
            "properties": {
               "key": {
                  "description": "Unified Edge Profile Tag Key",
                  "type": "string",
                  "default": "",
                  "minLength": 1,
                  "maxLength": 128
               },
               "value": {
                  "description": "Unified Edge Profile Tag Value",
                  "type": "string",
                  "default": "",
                  "minLength": 0,
                  "maxLength": 256
               }
            },
            "additionalProperties": false,
            "required": [
               "key"
            ]
         },
         "minItems": 1
      },
      "local_user_policy": {
         "description": "Unified Edge Profile Local User Policy",
         "type": "string",
         "default": ""
      },
      "network_connectivity_policy": {
         "description": "Unified Edge Profile Network Connectivity Policy",
         "type": "string",
         "default": ""
      },
      "ntp_policy": {
         "description": "Unified Edge Profile NTP Policy",
         "type": "string",
         "default": ""
      },
      "operational_state": {
         "description": "Unified Edge Profile - Operational State",
         "type": "object",
         "properties": {
            "config_state": {
               "description": "Indicates a profile's configuration deploying state",
               "type": "string",
               "enum": [
                  "None",
                  "Not-assigned",
                  "Assigned",
                  "Preparing",
                  "Validating",
                  "Configuring",
                  "UnConfiguring",
                  "Analyzing",
                  "Activating",
                  "Inconsistent",
                  "Associated",
                  "Failed",
                  "Not-complete",
                  "Waiting-for-resource"
               ],
               "default": "None"
            },
            "profile_state": {
               "description": "Combined state (configState, and operational state of the associated physical resource) to indicate the current state of the profile.",
               "type": "string"
            }
         },
         "additionalProperties": false
      },
      "port_policies": {
         "description": "Unified Edge Profile Port Policies",
         "type": "object",
         "properties": {
            "ecmc_a": {
               "description": "Unified Edge Profile Port Policy for Edge Chassis Management Controller A",
               "type": "string",
               "default": ""
            },
            "ecmc_b": {
               "description": "Unified Edge Profile Port Policy for Edge Chassis Management Controller B",
               "type": "string",
               "default": ""
            }
         },
         "additionalProperties": false
      },
      "power_policy": {
         "description": "Unified Edge Profile Power Policy",
         "type": "string",
         "default": ""
      },
      "switch_control_policy": {
         "description": "Unified Edge Profile Switch Control Policy",
         "type": "string",
         "default": ""
      },
      "syslog_policy": {
         "description": "Unified Edge Profile Syslog Policy",
         "type": "string",
         "default": ""
      },
      "system_qos_policy": {
         "description": "Unified Edge Profile System QoS Policy",
         "type": "string",
         "default": ""
      },
      "thermal_policy": {
         "description": "Unified Edge Profile Thermal Policy",
         "type": "string",
         "default": ""
      },
      "unified_edge_profile_template": {
         "description": "Source Unified Edge Profile Template from which this Unified Edge Profile has been derived",
         "type": "string",
         "default": ""
      },
      "vlan_policies": {
         "description": "Unified Edge Profile VLAN Policies",
         "type": "object",
         "properties": {
            "ecmc_a": {
               "description": "Unified Edge Profile VLAN Policy for Edge Chassis Management Controller A",
               "type": "string",
               "default": ""
            },
            "ecmc_b": {
               "description": "Unified Edge Profile VLAN Policy for Edge Chassis Management Controller B",
               "type": "string",
               "default": ""
            }
         },
         "additionalProperties": false
      }
   },
   "additionalProperties": false,
   "required": [
      "name"
   ]
}